#. Plugin Name of the plugin
#: rather-simple-polylang-free-extras.php
msgid "Rather Simple Polylang Free Extras"
msgstr ""

#. Description of the plugin
#: rather-simple-polylang-free-extras.php
msgid ""
"Enhances the free version of Polylang with basic REST API support, a "
"language switcher block, a language filter for block-based widgets and basic "
"localization for block template parts."
msgstr ""

